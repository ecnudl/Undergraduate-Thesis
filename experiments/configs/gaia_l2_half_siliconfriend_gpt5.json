  "storage_backend": {
    "type": "json",
    "config": {}
  },
  "retrieval_strategy": {
    "type": "semantic",
    "config": {}
  },
  "management_preset": "none",
  "notes": [
    "SiliconFriend baseline adapted as a retrieval-only memory backend for GAIA."
  ]
}
