{
  "name": "longmemeval_s_balanced_siliconfriend_gpt5",
  "provider": "siliconfriend",
  "dataset": "longmemeval",
  "split": "s_cleaned",
  "selection_file": "./experiments/configs/longmemeval_s_balanced_subset.json",
  "agent": "long_context_qa",
  "model": "gpt-5",
  "judge_model": "gpt-5",
  "api_base": "https://api-vip.codex-for.me/v1",
  "openai_base_url": "https://api-vip.codex-for.me/v1",
  "embedding_device": "cpu",
  "seed": 42,
  "max_steps": 1,
  "token_budget": 1024,
  "concurrency": 1,
  "summary_interval": 8,
  "prompts_type": "default",
  "enable_memory_evolution": true,
  "shared_memory_provider": false,
  "notes": [
    "Balanced LongMemEval_S subset using the MemoryBank-SiliconFriend baseline."
  ],
  "provider_config": {
    "user_name": "longmemeval_eval",
    "memory_file": "longmemeval_memory.json",
    "embedding_model": "minilm-l6",
    "response_mode": "trajectory_summary",
    "top_k": 3
  },
  "extraction_config": {
    "enabled_prompts": [],
    "prompt_dir": ".",
    "top_k": 0
  },
  "storage_backend": {
    "type": "json",
    "config": {}
  },
  "retrieval_strategy": {
    "type": "semantic",
    "config": {}
  },
  "management_preset": "none"
}
