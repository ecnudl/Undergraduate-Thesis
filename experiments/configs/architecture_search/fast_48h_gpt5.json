{
  "_comment": "48-hour budget architecture search with gpt-5, intermediate checkpoints, and no-memory baseline",

  "search_name": "fast_48h_gpt5",

  "dataset": {
    "name": "gaia",
    "split": "validation",
    "infile": "./data/gaia/validation/metadata.jsonl",
    "proxy_indices": "[level1]1-3 [level2]1-2",
    "holdout_indices": "[level1]1-10 [level2]1-10 [level3]1-4",
    "holdout_datasets": ["gaia"]
  },

  "runner": {
    "model": "gpt-5",
    "judge_model": "gpt-5",
    "api_base": "https://api-vip.codex-for.me/v1",
    "force_stream": true,
    "max_steps": 40,
    "token_budget": 8192,
    "concurrency": 1,
    "seed": 42,
    "prompts_type": "default",
    "summary_interval": 8
  },

  "anchor": {
    "extraction": "mixed_all",
    "storage": "hybrid",
    "retrieval": "hybrid",
    "management": "json_full"
  },

  "phase_a": {
    "top_k": {
      "extraction": 2,
      "storage": 2,
      "retrieval": 2,
      "management": 2
    },
    "run_no_memory_baseline": true,
    "min_spread_threshold": 0.08
  },

  "phase_b": {
    "top_elites": 5,
    "max_combinations": 20,
    "min_top_spread": 0.05
  },

  "phase_c": {
    "skip": true
  },

  "phase_d": {
    "top_n": 3,
    "datasets": ["gaia"]
  },

  "scoring": {
    "task_score_weight": 0.80,
    "token_cost_weight": 0.10,
    "latency_weight": 0.05,
    "memory_size_weight": 0.05
  },

  "output_root": "./experiments/results/architecture_search"
}
