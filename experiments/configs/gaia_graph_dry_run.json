{
  "name": "gaia_graph_hybridgraph_dryrun",
  "provider": "modular",
  "model": "gpt-5",
  "judge_model": "gpt-5",
  "agent": "mm_search_agent",
  "dataset": "gaia",
  "split": "validation",
  "seed": 7,
  "sample_num": 2,
  "max_steps": 6,
  "token_budget": 4096,
  "concurrency": 1,
  "shared_memory_provider": true,
  "dry_run": true,
  "prompts_type": "default",
  "enable_memory_evolution": true,
  "extraction_config": {
    "enabled_prompts": ["tip", "insight"],
    "prompt_dir": ".",
    "top_k": 5
  },
  "storage_backend": {
    "type": "graph",
    "config": {}
  },
  "retrieval_strategy": {
    "type": "hybrid_graph",
    "config": {
      "graph_weight": 1.0,
      "semantic_weight": 1.0,
      "bm25_weight": 0.6
    }
  },
  "management_preset": "graph_full"
}
